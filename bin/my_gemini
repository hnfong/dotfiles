#!/usr/bin/env python3

# Example usage: ./my_gemini -m 3.1-pro (io: stdin/stdout)

# 🤖 Generated by Gemini
# Links to managing this thing:
# - https://console.cloud.google.com/vertex-ai/studio
# - https://console.cloud.google.com/

import sys
import json
import urllib.request
import urllib.error
import getopt
from pathlib import Path

# DEFAULT_MODEL = "gemini-3.1-pro-preview"  # https://ai.google.dev/gemini-api/docs/models/gemini-3.1-pro-preview
# DEFAULT_MODEL = "gemini-3.1-flash-lite-preview" # https://ai.google.dev/gemini-api/docs/models/gemini-3.1-flash-lite-preview
DEFAULT_MODEL = "gemini-3-flash-preview" # https://ai.google.dev/gemini-api/docs/models/gemini-3-flash-preview

_model_names = [
    "gemini-3.1-pro-preview",
    "gemini-3-flash-preview",
    "gemini-3.1-flash-lite-preview",
]

def main():
    # 1. Read input from file arg or stdin
    opt_list, args = getopt.getopt(sys.argv[1:], "m:")
    opts = dict(opt_list)
    model_name = opts.get("-m", DEFAULT_MODEL)
    if model_name not in _model_names:
        # Try to find a match
        # Try to find a match using substring matching
        matched = False
        for candidate in _model_names:
            if model_name.lower() in candidate.lower():
                model_name = candidate
                matched = True
                break

        if not matched:
            print(f"Error: Model '{model_name}' not found.", file=sys.stderr)
            sys.exit(1)


    print("Using model: ", model_name)

    if len(args) > 0:
        in_file = args[0]
        try:
            with open(in_file, 'r', encoding='utf-8') as f:
                prompt = f.read()
        except Exception as e:
            print(f"Error reading file {in_file}: {e}", file=sys.stderr)
            sys.exit(1)
    else:
        if sys.stdin.isatty():
            # print("Enter your prompt (Press Ctrl+D to submit):", file=sys.stderr)
            # print("Enter your prompt (Press Ctrl+D to submit):", file=sys.stderr)
            sys.stderr.write("> ")
            sys.stderr.flush()
            pass
        prompt = sys.stdin.read()

    if not prompt.strip():
        print("Error: Input is empty.", file=sys.stderr)
        sys.exit(1)

    # 2. Read the API key
    key_path = Path.home() / ".vertexai.key"
    if not key_path.exists():
        print(f"Error: API key file not found at {key_path}", file=sys.stderr)
        sys.exit(1)

    api_key = key_path.read_text(encoding='utf-8').strip()

    # 3. Construct Payload and Request
    url = f"https://aiplatform.googleapis.com/v1/publishers/google/models/{model_name}:streamGenerateContent?key={api_key}"

    payload = {
        "contents": [
            {
                "role": "user",
                "parts": [{"text": prompt}]
            }
        ],
        "generationConfig": {
            "thinkingConfig": {
                "thinkingLevel": "LOW" # "MINIMAL" not supported in gemini
            }
        }
    }

    data = json.dumps(payload).encode('utf-8')
    req = urllib.request.Request(url, data=data, method='POST')
    req.add_header('Content-Type', 'application/json')

    # 4. Make request and Stream Response
    try:
        with urllib.request.urlopen(req) as response:
            decoder = json.JSONDecoder()
            buffer = ""

            while True:
                # Read chunks dynamically
                chunk = response.read(128)

                if not chunk:
                    break

                buffer += chunk.decode('utf-8')

                # Strip out array wrapping `[`, `]` and commas separating JSON objects
                buffer = buffer.lstrip("[\r\n ,]")

                while buffer:
                    try:
                        # Attempt to parse a complete JSON object from the buffer
                        obj, idx = decoder.raw_decode(buffer)

                        # Extract the text from the specific model chunk payload
                        candidates = obj.get("candidates", [])
                        if candidates:
                            for part in candidates[0].get("content", {}).get("parts", []):
                                if "text" in part:
                                    sys.stdout.write(part["text"])
                                    sys.stdout.flush() # Force write output immediately

                        # Advance buffer string to process next chunk
                        buffer = buffer[idx:].lstrip("[\r\n ,]")
                    except json.JSONDecodeError:
                        # Object not fully downloaded yet. Wait for next stream chunk.
                        break

        sys.stdout.write("\n")
        sys.stdout.flush()

    except urllib.error.URLError as e:
        print(f"\nAPI Request failed: {e}", file=sys.stderr)
        if hasattr(e, 'read'):
            print(e.read().decode('utf-8'), file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()

